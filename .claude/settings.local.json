{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(timeout 5 python:*)",
      "Bash(perl -i -pe:*)",
      "Bash(dir:*)",
      "mcp__chrome-devtools__*",
      "Bash(for f in nicegui/prototypes/history/*.py nicegui/prototypes/prototype_*.py)",
      "Bash(for f in nicegui/prototypes/records/*.py)",
      "Bash(findstr:*)",
      "Bash(for f in nicegui/prototypes/scoring/*.py)",
      "Bash(python -m py_compile:*)",
      "Bash(for:*)",
      "Bash(do python -m py_compile \"$f\")",
      "Bash(echo:*)",
      "Bash(done)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(python:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -c \"[System.Media.SystemSounds]::Question.Play()\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -c \"[System.Media.SystemSounds]::Beep.Play()\""
          }
        ]
      }
    ]
  }
}
